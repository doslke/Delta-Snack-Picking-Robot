/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, rgb(252, 250, 237) 0%, rgba(252, 250, 237, 0.55) 22%, rgba(252, 250, 237, 0.12) 50%, rgba(255, 255, 255, 0) 100%);
}

.brand-logo-wrap {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
  width: 750rpx;
}

.brand-logo {
  width: 750rpx;
  display: block;
  -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding-top: 360rpx;
  padding-bottom: 28rpx;
  box-sizing: border-box;
}

/* 商品明细卡片：全宽铺满，无圆角无阴影 */
.list-card {
  background: #fff;
  width: 100%;
  box-sizing: border-box;
  padding: 36rpx 0 0;
  margin-bottom: 0;
  border-bottom: 16rpx solid #F7F7F7;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 24rpx;
  padding: 0 28rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  letter-spacing: 1rpx;
}

/* 列表动画容器 */
.table-body {
  animation: slideUp 0.35s ease-out both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 表格 */
.table-header {
  display: none;
}

.table-row {
  display: flex;
  flex-direction: row;
  padding: 24rpx 28rpx;
  align-items: center;
  border-bottom: 1rpx solid #F2F2F2;
  gap: 24rpx;
}

.table-row:last-child {
  border-bottom: none;
}

.row-even {
  background-color: #fff;
}

.row-odd {
  background-color: #FAFAFA;
}

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 12rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
}

.item-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.meta-weight {
  font-size: 30rpx;
  color: #222;
  font-weight: bold;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.meta-sep {
  font-size: 24rpx;
  color: #ccc;
}

.item-price {
  font-size: 32rpx;
  font-weight: bold;
}

.empty-wrap {
  padding: 72rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #ccc;
  letter-spacing: 2rpx;
}

/* 支付区域 */
.pay-section {
  padding: 8rpx 24rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pay-tips {
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 28rpx;
  letter-spacing: 1rpx;
}

.pay-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF5722, #FF8C5A);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  text-align: center;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(255, 87, 34, 0.38);
  letter-spacing: 3rpx;
  transition: opacity 0.15s ease;
}

.pay-btn:active {
  opacity: 0.82;
}

.pay-btn[disabled] {
  background: linear-gradient(135deg, #ddd, #e8e8e8);
  box-shadow: none;
  color: #bbb;
}

/* ── 未绑定：扫码引导卡片 ─────────────────────────────────────────────────── */
.bind-card {
  margin: 48rpx 32rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 64rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.bind-icon {
  width: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.25;
}

.bind-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 16rpx;
}

.bind-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 48rpx;
}

.scan-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF5722, #FF8C5A);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(255, 87, 34, 0.35);
  letter-spacing: 2rpx;
}

.scan-btn[disabled] {
  background: linear-gradient(135deg, #ddd, #e8e8e8);
  box-shadow: none;
  color: #bbb;
}

/* ── 已绑定：购物车状态栏 ─────────────────────────────────────────────────── */
.cart-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: #FFF8F5;
  border-bottom: 2rpx solid #FFE0D6;
}

.cart-bar-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.cart-bar-label {
  font-size: 24rpx;
  color: #999;
}

.cart-bar-id {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF5722;
  letter-spacing: 1rpx;
}

.unbind-btn {
  font-size: 22rpx;
  color: #999;
  background: transparent;
  border: 1rpx solid #ddd;
  border-radius: 24rpx;
  padding: 6rpx 24rpx;
  line-height: 1.6;
  min-height: unset;
}

.unbind-btn::after {
  border: none;
}
